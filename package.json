{
  "name": "epiconcept-notes-api",
  "version": "1.0.0",
  "description": "Multi-tenant Notes API — Epiconcept technical test",
  "private": true,
  "scripts": {
    "start:dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "migration:run": "ts-node -r tsconfig-paths/register src/database/migrate.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/database/seed.ts",
    "test:e2e": "npm --prefix frontend run test:e2e",
    "test:e2e:ui": "npm --prefix frontend run test:e2e:ui",
    "test:e2e:report": "npm --prefix frontend run test:e2e:report"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "kysely": "^0.27.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sql.js": "^1.14.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.17.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
